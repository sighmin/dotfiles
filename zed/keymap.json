// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor && vim_mode != insert",
    "bindings": {
      "t n": "workspace::NewFile",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {},
  },
  {
    "context": "Workspace || Editor",
    "bindings": {
      // Navigate between panes
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "bindings": {
      // Resize panes
      "ctrl-a shift-k": "vim::ResizePaneUp",
      "ctrl-a shift-j": "vim::ResizePaneDown",
      "ctrl-a shift-h": "vim::ResizePaneLeft",
      "ctrl-a shift-l": "vim::ResizePaneRight",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-g": "git_panel::ToggleFocus",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-shift-g": "git_panel::ToggleFocus",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      // Writing-zen (Snacks.zen / Goyo equivalent): centered narrow column,
      // docks + tab bar + line numbers + indent guides hidden.
      // Every action is a true toggle, so `space w` again restores everything.
      // Soft wrap is left alone here (it's on globally) and toggled by `space n`.
      "space w": [
        "action::Sequence",
        [
          "workspace::ToggleAllDocks",
          "multi_workspace::ToggleWorkspaceSidebar",
          "editor::ToggleTabBar",
          "editor::ToggleLineNumbers",
          "editor::ToggleIndentGuides",
          "workspace::ToggleCenteredLayout",
        ],
      ],
      // Toggle soft wrap (on globally via settings; flip off/on when needed).
      "space n": "editor::ToggleSoftWrap",
    },
  },
]
